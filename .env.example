# ===========================================
# Copy this to .env.local and fill the values
# ===========================================

# ---------- Supabase (required) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Site / SEO ----------
NEXT_PUBLIC_SITE_URL=https://www.studymitra.in

# ---------- Cron (for auto-publish) ----------
CRON_SECRET=your-random-secret-string

# ---------- Gemini (for auto-generated posts) ----------
# Must be from a NEW Google Cloud project if you see CONSUMER_SUSPENDED.
# In AI Studio: "Create API key in new project" (not existing project).
GEMINI_API_KEY=your-gemini-api-key
# Optional override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
