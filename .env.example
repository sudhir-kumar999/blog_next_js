# ===========================================
# Copy this to .env.local and fill the values
# ===========================================

# ---------- Supabase (required) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Site / SEO ----------
NEXT_PUBLIC_SITE_URL=https://www.studymitra.in

# ---------- Cron (for auto-publish) ----------
CRON_SECRET=your-random-secret-string

# ---------- Gemini (for auto-generated posts) ----------
# Must be from a NEW Google Cloud project if you see CONSUMER_SUSPENDED.
# In AI Studio: "Create API key in new project" (not existing project).
GEMINI_API_KEY=your-gemini-api-key
# Primary model (default: gemini-2.5-flash — use ONE model to save quota)
# GEMINI_MODEL=gemini-2.5-flash
# Optional fallback only if primary 404s (avoid extra calls)
# GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# Shorter/faster posts on Vercel Hobby (60s limit)
# GEMINI_COMPACT=true
